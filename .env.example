# ─────────────────────────────────────────────────────────────────────────────
# SportRise.de – Umgebungsvariablen (Vorlage)
# Kopiere diese Datei als .env.local und trage deine Werte ein.
# NIEMALS .env.local in Git committen! (.gitignore schützt dich bereits)
# ─────────────────────────────────────────────────────────────────────────────

# ── Datenbank (Supabase PostgreSQL) ──────────────────────────────────────────
# DSGVO-Pflicht: Nur EU-Server verwenden (Supabase Frankfurt: ap-southeast-1 NICHT!)
# Supabase Dashboard → Settings → Database → Connection string → URI
# pgbouncer=true + connection_limit=1 ist Pflicht für Serverless (Next.js)!
DATABASE_URL=""

# Direkte Verbindung ohne PgBouncer – nur für Prisma-Migrationen (db push/migrate)
# Supabase Dashboard → Settings → Database → Connection string → URI (ohne ?pgbouncer)
DIRECT_URL=""

# ── NextAuth.js v5 ────────────────────────────────────────────────────────────
# Zufälliger Geheimschlüssel (min. 32 Zeichen) – generieren mit:
# openssl rand -base64 32
# In NextAuth v5 wird dieser Key als AUTH_SECRET gelesen.
NEXTAUTH_SECRET=""

# Basis-URL der App (lokal: http://localhost:3000 | Produktion: https://sportrise.de)
NEXTAUTH_URL="http://localhost:3000"

# ── Supabase Client (öffentliche Keys – safe für den Browser) ─────────────────
# Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=""

# Supabase Dashboard → Settings → API → Project API Keys → anon public
# Dieser Key ist öffentlich – er ist durch Row Level Security (RLS) geschützt.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Supabase Dashboard → Settings → API → Project API Keys → service_role
# ACHTUNG: Dieser Key umgeht RLS komplett – NUR server-seitig verwenden!
# Niemals in NEXT_PUBLIC_* oder Client-Code einsetzen!
SUPABASE_SERVICE_ROLE_KEY=""

# ── KI – Google Gemini (kostenloser Free Tier) ────────────────────────────────
# aistudio.google.com → Get API key → Create API key
# Free Tier: 15 Anfragen/Minute, 1.000.000 Token/Tag – ausreichend für MVP
GEMINI_API_KEY=""

# ── KI – Anthropic Claude (optional, für zukünftige Features) ────────────────
# console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=""

# Rate-Limit: Maximale KI-Generierungen pro User pro Monat (Standard: 3)
# Schützt vor Kosten-Explosion auf dem Free Tier
KI_MAX_GENERATIONS_PER_MONTH=3

# ── OAuth – Google Login ──────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Dienste → Anmeldedaten → OAuth 2.0-Client-IDs
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── E-Mail: EmailJS (Admin-Benachrichtigungen) ────────────────────────────────
# emailjs.com → Account → Services → Service ID
NEXT_PUBLIC_EMAILJS_SERVICE_ID=""

# emailjs.com → Email Templates → Template ID (für Vereins-Einreichungen)
NEXT_PUBLIC_EMAILJS_TEMPLATE_VEREIN=""

# emailjs.com → Email Templates → Template ID (für Turnier-Einreichungen)
NEXT_PUBLIC_EMAILJS_TEMPLATE_TURNIER=""

# emailjs.com → Account → API Keys → Public Key
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=""

# E-Mail-Adresse des Admins (erhält Benachrichtigungen bei neuen Einreichungen)
ADMIN_EMAIL="admin@sportrise.de"

# ── E-Mail: Resend (transaktionale User-Mails) ────────────────────────────────
# resend.com → API Keys → Create API Key
RESEND_API_KEY=""

# Absender-Adresse (muss auf verifizierter Domain liegen)
RESEND_FROM_EMAIL="noreply@sportrise.de"

# ── Google Maps ───────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Dienste → Maps JavaScript API aktivieren → API Key
# Einschränkung empfohlen: HTTP-Referrer auf deine Domain begrenzen
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# ── Sicherheit ────────────────────────────────────────────────────────────────
# Schützt Cron-Job-Endpunkte vor unbefugtem Aufruf
# Generieren mit: openssl rand -base64 32
CRON_SECRET=""

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="SportRise"
NODE_ENV="development"
